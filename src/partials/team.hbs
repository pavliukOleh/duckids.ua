<section id="team" class="team" aria-labelledby="team-title">
  <div class="team__wave team__wave--top" aria-hidden="true"></div>
  <div class="team__inner container">
    <h2 id="team-title" class="team__title">Наша команда</h2>
    <p class="team__subtitle">Ми бачимо в кожній дитині потенціал — і підтримуємо його з турботою та професійністю.</p>
    <ul class="team__list">
      <li class="team__card">
        <div class="team__photo-wrap">
          <img class="team__photo" src="/img/raw/ourTeamPhoto1.png" alt="Аліна Гринюк" width="320" height="380" loading="lazy" />
        </div>
        <div class="team__info">
          <p class="team__name">Аліна Гринюк</p>
          <p class="team__role">Логопед</p>
          <p class="team__experience">7 років досвіду роботи з дітьми</p>
          <p class="team__desc">Розвиток уваги, пам'яті та емоційної регуляції</p>
        </div>
      </li>
      <li class="team__card">
        <div class="team__photo-wrap">
          <img class="team__photo" src="/img/raw/ourTeamPhoto2.png" alt="Діана Мельник" width="320" height="380" loading="lazy" />
        </div>
        <div class="team__info">
          <p class="team__name">Діана Мельник</p>
          <p class="team__role">Нейропсихолог</p>
          <p class="team__experience">8 років досвіду</p>
          <p class="team__desc">Працює з когнітивним та емоційним розвитком дітей</p>
        </div>
      </li>
    </ul>
  </div>
  <div class="team__wave team__wave--bottom" aria-hidden="true"></div>
</section>
