<header class="site-header" role="banner">
  <div class="site-header__wrap">
  <div class="site-header__inner">
    <a class="site-header__logo" href="{{baseUrl}}" aria-label="Duckids — на головну">
      <img
        class="site-header__logo-icon"
        src="{{baseUrl}}img/raw/Logo.png"
        alt="Duckids"
        width="71"
        height="44"
        fetchpriority="high"
      />
    </a>
    <nav class="site-header__nav" aria-label="Головна навігація">
      <a class="site-header__nav-link" href="#about">Про нас</a>
      <a class="site-header__nav-link" href="#team">Команда</a>
      <a class="site-header__nav-link" href="#space">Простір</a>
      <a class="site-header__nav-link" href="#reviews">Відгуки</a>
      <a class="site-header__nav-link" href="#contacts">Контакти</a>
    </nav>
    <a class="site-header__cta" href="#feedback">Отримати консультацію</a>
    <button
      type="button"
      class="site-header__burger"
      aria-label="Відкрити меню"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-burger
    >
      <span class="site-header__burger-line"></span>
      <span class="site-header__burger-line"></span>
      <span class="site-header__burger-line"></span>
    </button>
  </div>
  </div>
</header>

<div
  id="mobile-menu"
  class="mobile-menu"
  aria-hidden="true"
  data-mobile-menu
>
  <div class="mobile-menu__inner">
    <div class="mobile-menu__head">
      <a class="mobile-menu__logo" href="{{baseUrl}}" aria-label="Duckids — на головну">
        <img
          class="mobile-menu__logo-icon"
          src="{{baseUrl}}img/raw/Logo.png"
          alt="Duckids"
          width="71"
          height="44"
        />
      </a>
      <button
        type="button"
        class="mobile-menu__close"
        aria-label="Закрити меню"
        data-menu-close
      >
        <span aria-hidden="true">&times;</span>
      </button>
    </div>
    <nav class="mobile-menu__nav" aria-label="Мобільна навігація">
      <a class="mobile-menu__link" href="#about">Про нас</a>
      <a class="mobile-menu__link" href="#team">Команда</a>
      <a class="mobile-menu__link" href="#space">Простір</a>
      <a class="mobile-menu__link" href="#reviews">Відгуки</a>
      <a class="mobile-menu__link" href="#contacts">Контакти</a>
    </nav>
  </div>
</div>
